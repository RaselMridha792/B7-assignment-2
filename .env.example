# PostgreSQL connection string.
# Local example:
DATABASE_URL=postgresql://postgres:password@localhost:5432/devpulse
# Hosted example (NeonDB / Supabase): use the connection string they provide.

# Set to "true" for hosted Postgres (Neon/Supabase) that requires SSL.
# Leave unset to auto-detect (off for localhost, on otherwise).
# DATABASE_SSL=true

# Secret used to sign JWTs — use a long random value in production.
JWT_SECRET=change-this-secret

# JWT expiry (e.g. 8h, 1d).
JWT_EXPIRES_IN=8h

# Server port.
PORT=5000

# Allowed CORS origin ("*" allows any; set to your frontend URL in production).
CORS_ORIGIN=*
